{
    "name": "react-native-bright-sdk",
    "version": "1.0.6",
    "description": "React Native plugin to bridge BrightSDK with native Android",
    "main": "index.js",
    "author": "Vladislav S <vladislavs@brightdata.com>",
    "license": "MIT",
    "repository": {
      "type": "git",
      "url": "https://github.com/vladislavs-luminati/bright-sdk-react-native.git"
    },
    "peerDependencies": {
      "react": ">=17.0.0",
      "react-native": ">=0.68.0"
    },
    "files": [
      "android/build.gradle",
      "android/src/main/AndroidManifest.xml",
      "android/src/main/java/com/brightsdk/react/BrightSdkHelper.java",
      "android/src/main/java/com/brightsdk/react/BrightSdkNativeModule.java",
      "android/src/main/java/com/brightsdk/react/BrightSdkNativeModulePackage.java",
      "index.js"
    ],
    "react-native": {
      "android": {
        "packageImportPath": "import com.brightsdk.react.BrightSdkNativeModulePackage;",
        "packageInstance": "new BrightSdkNativeModulePackage()"
      }
    },
    "scripts": {
      "test": "node --test tests/*.test.mjs",
      "pack": "npm pack --silent && mv *.tgz ./dist",
      "pack:check": "npm pack --json --dry-run"
    }
  }
  